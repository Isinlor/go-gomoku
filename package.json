{
  "name": "gogomoku",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "check": "npm run coverage",
    "archive": "git archive -o latest-code.zip HEAD",
    "patch": "git format-patch --root master --stdout > latest-code.patch",
    "latest-code": "npm run archive && npm run patch",
    "serve": "npx http-server -p 8080 browser-demo",
    "compare": "npm run build && node browser-demo/build/src/compare.js",
    "test:e2e": "npx playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "vue": "^3.5.31"
  }
}
